{
  "name": "@growtheffectai/growtheffect-embed-react",
  "version": "3.0.3",
  "description": "React library to display growtheffect chatbot on your website",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/growtheffectai/GrowtheffectEmbedReact.git"
  },
  "homepage": "https://github.com/growtheffectai/GrowtheffectEmbedReact#readme",
  "bugs": {
    "url": "https://github.com/growtheffectai/GrowtheffectEmbedReact/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "scripts": {
    "dev": "rollup --watch --config rollup.config.js",
    "build": "rollup --config rollup.config.js",
    "prepack": "pnpm build",
    "lint": "eslint --fix \"src/**/*.ts*\""
  },
  "keywords": [
    "growtheffect",
    "chatbot",
    "react",
    "web-component"
  ],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@ladle/react": "2.5.1",
    "@babel/preset-react": "7.26.3",
    "@babel/preset-typescript": "7.21.4",
    "@rollup/plugin-babel": "6.0.3",
    "@rollup/plugin-node-resolve": "15.0.1",
    "@rollup/plugin-terser": "0.4.0",
    "@rollup/plugin-typescript": "11.0.0",
    "@types/node": "18.15.11",
    "@types/react": "18.0.32",
    "eslint": "8.37.0",
    "@growtheffectai/chat-component": "^3.0.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rollup": "3.20.2",
    "rollup-plugin-typescript-paths": "1.4.0",
    "tslib": "2.5.0",
    "tsx": "3.12.6",
    "typescript": "5.0.3"
  },
  "peerDependencies": {
    "@growtheffectai/chat-component": "*",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  }
}
